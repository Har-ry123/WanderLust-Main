<% layout("layouts/boilerplate") %>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="p-5">
                <h1 class="mb-4 fw-bold">Login on Wanderlust</h1>
                <form action="/login" method="POST" class="needs-validation" novalidate>
                    <div class="mb-4">
                        <label for="username" class="form-label">Username</label>
                        <input name="username" id="username" type="text" class="form-control form-control-lg" required />
                        <div class="valid-feedback d-block mt-2 text-success">Looks good!</div>
                        <div class="invalid-feedback d-block mt-2 text-danger">Please enter your username.</div>
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label">Password</label>
                        <input name="password" id="password" type="password" class="form-control form-control-lg" required />
                        <div class="valid-feedback d-block mt-2 text-success">Looks good!</div>
                        <div class="invalid-feedback d-block mt-2 text-danger">Please enter your password.</div>
                    </div>

                    <button class="btn btn-success btn-lg w-100 mt-2" type="submit">Login</button>
                </form>
                <p class="text-center mt-4">
                    Don't have an account? <a href="/signup" class="text-decoration-none">Sign Up</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control-lg {
        font-size: 1rem;
        padding: 0.75rem 1rem;
    }
    
    .btn-lg {
        font-size: 1rem;
        padding: 0.75rem 1rem;
    }
</style>
